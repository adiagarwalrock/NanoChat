<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include
            domain="file"
            path="datastore/" />
        <include
            domain="database"
            path="nanochat.db" />
        <include
            domain="database"
            path="nanochat.db-wal" />
        <include
            domain="database"
            path="nanochat.db-shm" />
    </cloud-backup>
    <device-transfer>
        <include
            domain="file"
            path="datastore/" />
        <include
            domain="database"
            path="nanochat.db" />
        <include
            domain="database"
            path="nanochat.db-wal" />
        <include
            domain="database"
            path="nanochat.db-shm" />
    </device-transfer>
</data-extraction-rules>
